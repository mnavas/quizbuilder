# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL quizbee user
DB_PASSWORD=change_this_strong_password

# ── API ───────────────────────────────────────────────────────────────────────
# JWT signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be stable — rotating it invalidates all active sessions
SECRET_KEY=change_this_64_char_random_string

# Admin account created on first startup (change immediately after first login)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_password

# ── Optional ──────────────────────────────────────────────────────────────────
# Restrict CORS to specific origins (comma-separated). Default "*" allows all.
# ALLOWED_ORIGINS=https://yourdomain.com
