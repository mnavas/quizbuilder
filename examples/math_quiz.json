              {"id":"c","content_json":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"$x^{12}$"}]}]}},
              {"id":"d","content_json":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"$x^6$"}]}]}}
            ],
            "correct_answer": "b",
            "explanation_json": {"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"$\\frac{x^3 \\cdot x^5}{x^4} = \\frac{x^{3+5}}{x^4} = \\frac{x^8}{x^4} = x^{8-4} = x^4$"}]}]},
