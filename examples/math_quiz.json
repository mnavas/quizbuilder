              {"id":"d","content_json":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"$x = \\frac{-c}{b}$"}]}]}}
            ],
            "correct_answer": "a",
            "explanation_json": {"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"The quadratic formula is $x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}$. The discriminant $b^2 - 4ac$ determines the number of real roots."}]}]},
